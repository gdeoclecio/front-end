# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Production build outputs
dist/
build/
out/
.next/

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.workspace

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Lock files (optional, but node_modules/ is the main one; keeping standard lock files trackable unless requested otherwise)
# yarn.lock, package-lock.json and pnpm-lock.yaml are usually tracked, so we keep them out of gitignore
